---
import { Icon } from "astro-icon/components";

import { useTranslations } from "../i18n/ui";
const t = useTranslations(Astro.currentLocale);
---

<section class="py-32 px-6 md:px-16 bg-[#f7f3ef] fade-in-section" id="events">  
  <div class="max-w-7xl mx-auto">
    <h2
      class="font-headline-lg-mobile md:font-headline-lg text-brand-primary mb-16 text-center"
    >
      {t("events.title")}
    </h2>
    <div class="max-w-4xl mx-auto flex flex-col space-y-6">
      <!-- Event 1 -->
      <div
        class="border-b border-brand-primary/20 pb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 hover:border-brand-primary transition-colors"
      >
        <div>
          <div
            class="font-label-sm text-[#716E11] uppercase tracking-widest mb-2"
          >
            OCT 14, 2024
          </div>
          <h3 class="font-headline-md text-brand-primary">Symphony Hall</h3>
          <p class="font-body-md text-brand-primary-on-surface">Chicago, IL</p>
        </div>
        <div class="flex items-center gap-4">
          <a
            class="font-label-sm text-label-sm text-brand-primary uppercase tracking-widest border-b border-transparent group-hover:border-brand-primary transition-all flex items-center gap-2"
            href="#"
          >
            {t("events.tickets")}
            <Icon name="mdi:arrow-forward" width="16" height="16" />
          </a>
        </div>
      </div>
      <!-- Event 2 -->
      <div
        class="border-b border-brand-primary/20 pb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 hover:border-brand-primary transition-colors"
      >
        <div>
          <div
            class="font-label-sm text-[#716E11] uppercase tracking-widest mb-2"
          >
            NOV 02, 2024
          </div>
          <h3 class="font-headline-md text-brand-primary">The Grand Theater</h3>
          <p class="font-body-md text-brand-primary-on-surface">New York, NY</p>
        </div>
        <div class="flex items-center gap-4">
          <a
            class="font-label-sm text-label-sm text-brand-primary uppercase tracking-widest border-b border-transparent group-hover:border-brand-primary transition-all flex items-center gap-2"
            href="#"
          >
            {t("events.tickets")}
            <Icon name="mdi:arrow-forward" width="16" height="16" />
          </a>
        </div>
      </div>

      <!-- Event 3 -->
      <div
        class="border-b border-brand-primary/20 pb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 hover:border-brand-primary transition-colors opacity-60"
      >
        <div>
          <div
            class="font-label-sm text-[#716E11] uppercase tracking-widest mb-2"
          >
            NOV 18, 2024
          </div>
          <h3 class="font-headline-md text-brand-primary">
            Walt Disney Concert Hall
          </h3>
          <p class="font-body-md text-brand-primary-on-surface">
            Los Angeles, CA
          </p>
        </div>
        <div class="flex items-center gap-4">
          <span
            class="px-3 py-1 bg-brand-primary/10 text-brand-primary font-label-sm uppercase rounded-sm border border-brand-primary/20"
            >Sold Out</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
