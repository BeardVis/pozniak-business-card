---
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Bio from "../components/about/Bio.astro";
import Footer from "../components/Footer.astro";

import { getImage } from "astro:assets";

import backgroundImage from "../assets/bg.svg";
const optimizedBackground = await getImage({ src: backgroundImage });

import { useTranslations } from "../i18n/ui";
const t = useTranslations(Astro.currentLocale);
---

<Layout title="Home">
  <Header />
  <main>
    <div
      class="fixed inset-0 z-0 pointer-events-none opacity-20"
      style={`background-image: url(${optimizedBackground.src}); background-repeat: no-repeat; background-size: cover; background-position: center; background-attachment: fixed;`}
    >
    </div>
    <div
      class="relative min-h-screen max-w-200 mx-auto bg-[#f7f3ef] pt-16 my-0 pb-24 px-14 md:my-32"
    >
      <Breadcrumb
        segments={[
          { title: t("site.page_title.index"), href: import.meta.env.BASE_URL || '/' },
          { title: t("site.page_title.about") },
        ]}
      />
      <Bio />
    </div>
  </main>
  <Footer />
</Layout>
