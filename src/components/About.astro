---
import { Image } from "astro:assets";
import aboutImage from "../assets/images/about-side.jpg";
---

<section class="py-32 px-6 md:px-16 fade-in-section" id="about">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row gap-16 items-center">
            <div class="w-full md:w-5/12 relative">
                <div class="aspect-3/4 relative overflow-hidden rounded-sm">
                    <Image
                        class="w-full h-full object-cover"
                        src={aboutImage}
                        alt="About photo."
                    />
                </div>
            </div>
            <div class="w-full md:w-7/12 md:pl-12">
                <h2
                    class="font-headline-lg-mobile md:font-headline-lg text-brand-primary mb-8 relative inline-block"
                >
                    Voice of the Soul
                    <span
                        class="absolute -bottom-2 left-0 w-1/3 h-px bg-brand-primary"
                    ></span>
                </h2>
                <div
                    class="font-body-lg text-body-lg text-on-surface-variant space-y-6 max-w-2xl"
                >
                    <p>
                        Veronika Pozniak merges the profound depth of classical
                        technique with the raw, emotional vulnerability of
                        contemporary storytelling. Her performances are not mere
                        concerts; they are intimate recitals designed to
                        resonate within the quiet spaces of the soul.
                    </p>
                    <p>
                        Trained in Europe's most prestigious conservatories, she
                        brings a uniquely modern, minimalist sophistication to
                        the stage, stripping away the superfluous to leave only
                        the pure, unadulterated power of the human voice.
                    </p>
                </div>
                <div class="mt-12 flex items-center gap-6">
                    <a
                        class="inline-flex items-center justify-center px-8 py-4 bg-brand-primary text-[#F1EDE4] font-label-sm uppercase tracking-widest hover:bg-surface-tint transition-colors"
                        href="#events"
                    >
                        View Upcoming Recitals
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
