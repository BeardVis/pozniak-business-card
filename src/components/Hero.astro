---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import coverImage from "../assets/images/cover.jpg";
import homepageData from "../data/homepage.json";
const content =
  homepageData[(Astro.currentLocale ?? "en") as keyof typeof homepageData];

import { useTranslations } from "../i18n/ui";
const t = useTranslations(Astro.currentLocale);
---

<section
  class="relative min-h-[90vh] md:min-h-screen flex items-end md:items-center px-6 md:px-16 pb-24 md:pb-0 pt-32"
>
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute inset-0 bg-black/20 z-10"></div>
    <Image
      src={coverImage}
      alt="Cover image."
      class="object-cover w-full h-full object-center"
    />
  </div>

  <div
    class="relative z-10 w-full max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-end md:items-center gap-8"
  >
    <div class="w-full md:w-1/2">
      <h1
        class="font-display-lg-mobile md:font-display-lg text-white uppercase tracking-tighter mb-4 leading-none mix-blend-difference drop-shadow-md"
      >
        {t("site.hero_name")}
      </h1>
      <p
        class="font-body-lg text-body-lg text-white/90 uppercase tracking-widest mb-8 mix-blend-difference"
      >
        {content.hero_subtitle}
      </p>

      <!-- Social Links -->
      <div class="flex space-x-6">
        <a
          aria-label="Instagram"
          class="text-white hover:text-[#eeb7d1] transition-colors"
          href="https://www.instagram.com/vpozniak_music"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="mdi:instagram" width="24" height="24" />
        </a>
        <a
          aria-label="Facebook"
          class="text-white hover:text-[#eeb7d1] transition-colors"
          href="https://www.facebook.com/profile.php?id=61575866916326"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="mdi:facebook" width="24" height="24" />
        </a>
        <a
          aria-label="Youtube"
          class="text-white hover:text-[#eeb7d1] transition-colors"
          href="https://youtube.com/@veronikapozniak?si=A26cpsOYInxNovC7"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="mdi:youtube" width="24" height="24" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .font-display-lg-mobile {
    font-family: var(--font-eb-garamond);
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 500;
  }

  .font-display-lg {
    font-family: var(--font-eb-garamond);
    font-size: 72px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 500;
  }
</style>
