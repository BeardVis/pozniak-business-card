---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import { marked } from "marked";

const pressCollection = await getCollection("press", ({ id }: any) => {
  return id.startsWith(Astro.currentLocale);
});

const sortedPress = [...pressCollection].sort((a, b) => {
  const posA = a.data.position ?? -Infinity;
  const posB = b.data.position ?? -Infinity;

  return posA - posB;
});

import EmblaCarousel from "./EmblaCarousel.astro";

import { useTranslations } from "../i18n/ui";
const t = useTranslations(Astro.currentLocale);
---

<section class="py-32 px-6 md:px-16 fade-in-section" id="press">
  <div class="mx-auto grid justify-center text-center text-brand-primary">

    {
      sortedPress.length > 1 ? (
        <EmblaCarousel autoScroll={true} loop={true}>
          {
            sortedPress.map((press) => (
              <article
                class="embla__slide prose font-body-md text-brand-primary-on-surface"
                set:html={marked.parse(press.data.quote)}
              />
            ))
          }
        </EmblaCarousel>
      ) : (
        sortedPress.map((press) => (
          <article
            class="embla__slide prose font-body-md text-brand-primary-on-surface"
            set:html={marked.parse(press.data.quote)}
          />
        ))
      )
    }

    <div
      class="flex flex-col items-center md:flex-row justify-center mt-12 gap-4 md:gap-8 w-full"
    >
      <div class="flex">
        <Icon name="mdi:radio" width="24" height="24" />
        <a
          class="ml-2"
          href="https://www.mujrozhlas.cz/nocni-mikroforum/host-veronika-pozniak-hudebnice-herecka"
          target="_blank"
          rel="noopener noreferrer">{t("press.listen_radio")}</a
        >
      </div>
      <div class="flex">
        <Icon name="mdi:newspaper-variant-outline" width="24" height="24" />
        <a
          class="ml-2"
          href="https://porohy.cz/veronika-poznyak-spiv-shho-yednaye-narodi-i-zczilyuye-serczya/"
          target="_blank"
          rel="noopener noreferrer">{t("press.read_article")}</a
        >
      </div>
      <div class="flex">
        <Icon name="mdi:download" width="24" height="24" />
        <a
          class="ml-2"
          href={`${import.meta.env.BASE_URL === "/" ? "" : import.meta.env.BASE_URL}/md_3-1704474865.pdf`}
          target="_blank"
          rel="noopener noreferrer">{t("press.download_article")}</a
        >
      </div>
    </div>
  </div>
</section>
