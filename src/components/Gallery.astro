---
import footerImage from "../assets/images/footer.jpg";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

import galleryData from "../data/gallery.json";

import { useTranslations } from "../i18n/ui";
const t = useTranslations(Astro.currentLocale);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/*.{jpeg,jpg,png,gif}",
);
---

<section class="py-32 px-6 md:px-16 fade-in-section" id="gallery">
  <div class="max-w-7xl mx-auto">
    <h2
      class="font-headline-lg-mobile md:font-headline-lg text-brand-primary mb-12 text-center"
    >
      {t("gallery.title")}
    </h2>

    <div class="embla">
      <div class="embla__viewport">
        <div class="embla__container">
          {
            galleryData.carousel_photos.map((photo: any) => {
              const imagePath = "/" + photo.image;
              if (!images[imagePath]) {
                console.error(`Image not found: ${imagePath}`);
                return null;
              }
              return (
                <div class="embla__slide">
                  <Image
                    src={images[imagePath]()}
                    alt="Cover image."
                    class="embla__slide__img"
                  />
                </div>
              );
            })
          }
        </div>
        <div class="embla__controls">
          <div class="embla__dots"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .embla {
    max-width: 48rem;
    margin: auto;

    --slide-height: 26rem;
    --slide-spacing: 1rem;
    --slide-size: 100%;
  }

  .embla__viewport {
    overflow: hidden;
  }

  .embla__container {
    display: flex;
    touch-action: pan-y pinch-zoom;
    margin-left: calc(var(--slide-spacing) * -1);
    /* height: 600px; */
    max-height: 100vh;
  }

  .embla__slide {
    transform: translate3d(0, 0, 0);
    flex: 0 0 var(--slide-size);
    min-width: 0;
    padding-left: var(--slide-spacing);
  }

  .embla__controls {
    display: flex;
    grid-template-columns: auto 1fr;
    justify-content: center;
    gap: 1.2rem;
    margin-top: 1.8rem;
  }

  .embla__dots {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: center;
    margin-right: calc((2.6rem - 1.4rem) / 2 * -1);
  }

  .embla__dot {
    -webkit-tap-highlight-color: rgba(var(--text-high-contrast-rgb-value), 0.5);
    -webkit-appearance: none;
    appearance: none;
    background-color: transparent;
    touch-action: manipulation;
    display: inline-flex;
    text-decoration: none;
    cursor: pointer;
    border: 0;
    padding: 0;
    margin: 0;
    width: 2.6rem;
    height: 2.6rem;

    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    position: relative;
  }

  .embla__dot:before,
  .embla__dot:after {
    width: 1.4rem;
    height: 1.4rem;

    border-radius: 50%;
    position: absolute;
    display: flex;
    align-items: center;
    content: "";
  }

  .embla__dot:before {
    border: 0.2rem solid var(--color-brand-primary);
  }

  .embla__dot:after {
    background-color: var(--color-brand-primary);
    opacity: 0;
  }

  .embla__dot--selected:after {
    opacity: 1;
  }

  .embla__slide__img {
    transform: translate3d(0, 0, 0);
    /* flex: 0 0 var(--slide-size); */
    min-width: 0;
    padding-left: var(--slide-spacing);
    height: var(--slide-height);
    max-height: 100vh;
    object-fit: contain;
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";
  import type { EmblaOptionsType, EmblaCarouselType } from "embla-carousel";

  function initCarousels() {
    const OPTIONS: EmblaOptionsType = {};
    const emblaNodes = document.querySelectorAll(".embla");

    emblaNodes.forEach((emblaNode) => {
      const viewportNode = emblaNode.querySelector(
        ".embla__viewport",
      ) as HTMLElement;
      const dotsNode = emblaNode.querySelector(".embla__dots") as HTMLElement;

      if (!viewportNode || !dotsNode) return;

      const emblaApi = EmblaCarousel(viewportNode, OPTIONS);
      addDotButtonAndClickHandlers(emblaApi, dotsNode);
    });
  }

  // Initialize on initial load
  initCarousels();
  // Initialize on ViewTransitions page load if applicable
  document.addEventListener("astro:page-load", initCarousels);

  function addDotButtonAndClickHandlers(
    emblaApi: EmblaCarouselType,
    dotsNode: HTMLElement,
  ): void {
    let dotNodes: HTMLElement[] = [];

    const addDotBtnsWithClickHandlers = (): void => {
      dotsNode.innerHTML = emblaApi
        .scrollSnapList()
        .map(() => '<button class="embla__dot" type="button"></button>')
        .join("");

      const scrollTo = (index: number): void => {
        emblaApi.scrollTo(index);
      };

      dotNodes = Array.from(dotsNode.querySelectorAll(".embla__dot"));
      dotNodes.forEach((dotNode, index) => {
        dotNode.addEventListener("click", () => scrollTo(index), false);
      });
    };

    const toggleDotButtonsActive = (): void => {
      const previous = emblaApi.previousScrollSnap();
      const selected = emblaApi.selectedScrollSnap();
      if (dotNodes[previous])
        dotNodes[previous].classList.remove("embla__dot--selected");
      if (dotNodes[selected])
        dotNodes[selected].classList.add("embla__dot--selected");
    };

    addDotBtnsWithClickHandlers();
    toggleDotButtonsActive();

    emblaApi
      .on("reInit", addDotBtnsWithClickHandlers)
      .on("reInit", toggleDotButtonsActive)
      .on("select", toggleDotButtonsActive);
  }
</script>
